{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "/static/$1",
            "continue": true
        },
        {
            "src": "/(.*)",
            "dest": "api/index.py"
        }
    ]
}